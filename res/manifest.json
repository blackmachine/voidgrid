{
  "name": "Main Terminal Scene",
  "version": "1.0",
  "assets": {
    "atlases": {
      "c64": "assets/c64.json"
    },
"scripts": {
      "pack_ui": "assets/ui.rhai",
	"demo_d": "assets/demo.rhai"
    },
    "shaders": {
      "chromatic": "assets/chromatic.fs",
	"scanline": "assets/scanline.fs"
    }
  },
  "glyphsets": {
    "composite": {
      "base": "c64",
      "merges": []
    }
  },
  "scene": {
    "nodes": [
      {
        "id": "main_buf",
        "type": "buffer",
        "name": "main",
        "width": 64,
        "height": 32,
        "glyphset": "composite",
        "z_index": 1,
        "dynamic": false,
	"shader": "scanline"
      },
      {
        "id": "back_buf",
        "type": "buffer",
        "name": "back",
        "width": 64,
        "height": 32,
        "glyphset": "composite",
        "z_index": -1,
        "dynamic": true,
        "parent": "main_buf"
      },
      {
        "id": "drop_zone_buf",
        "type": "buffer",
        "name": "drop_zone",
        "width": 40,
        "height": 1,
        "glyphset": "composite",
        "z_index": 100,
        "dynamic": true,
        "parent": "main_buf",
        "anchor": "BottomLeft",
        "local_x": 2,
        "local_y": -2
      },
      {
        "id": "shader_demo_buf",
        "type": "buffer",
        "name": "shader_demo",
        "width": 40,
        "height": 1,
        "glyphset": "composite",
        "dynamic": true,
        "parent": "main_buf",
        "local_x": 4,
        "local_y": 1,
        "shaders": [
           "chromatic",
           "scanline"
        ],
        "shader_padding": 4
      }
    ]
  }
}